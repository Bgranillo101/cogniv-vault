# Groq inference
GROQ_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# CORS (comma-separated origins). Dev default allows Vite.
CORS_ORIGINS=http://localhost:5173

# Agent config
VERIFY_THRESHOLD=0.8
MAX_ATTEMPTS=3

# Embedding model (local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
